NODE_ENV=production
PUBLIC_APP_URL=https://your-domain.com
API_BASE_URL=https://api.your-domain.com
CLIENT_ORIGIN=https://your-domain.com

DATABASE_URL=postgresql://postgres:root@postgres:5432/gate_progress
REDIS_URL=redis://redis:6379

JWT_SECRET=replace-with-64-char-secret
JWT_REFRESH_SECRET=replace-with-different-64-char-secret
COOKIE_SECRET=replace-with-cookie-secret

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

MAX_PDF_UPLOAD_MB=10
