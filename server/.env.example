# ==========================================
# GATEPEDIA - SERVER CONFIGURATION
# ==========================================

PORT=5000
NODE_ENV=development

# ==========================================
# FRONTEND
# ==========================================

CLIENT_ORIGIN=https://gatepedia.vercel.app
API_BASE_URL=https://gatepedia-api.onrender.com

# ==========================================
# SUPABASE POSTGRESQL
# Replace YOUR_SUPABASE_PASSWORD
# ==========================================
# Supabase PostgreSQL

DATABASE_URL="postgresql://postgres.bguigbegpldhfqjvyown:1234@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

DIRECT_URL="postgresql://postgres.bguigbegpldhfqjvyown:1234@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"
# ==========================================
# JWT AUTHENTICATION
# ==========================================

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================
# COOKIES & SECURITY
# ==========================================

COOKIE_SECRET=replace-with-cookie-signing-secret

CSRF_COOKIE_NAME=gate_csrf
REFRESH_COOKIE_NAME=gate_refresh_token

# ==========================================
# RATE LIMITING
# ==========================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600

AUTH_RATE_LIMIT_MAX=30

# ==========================================
# REDIS (OPTIONAL)
# Leave blank if not using Redis
# ==========================================

REDIS_URL=

# ==========================================
# OPENAI (OPTIONAL)
# ==========================================

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ==========================================
# FILE UPLOADS
# ==========================================

MAX_PDF_UPLOAD_MB=10